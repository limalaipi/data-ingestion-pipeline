# Warehouse (target) — your Postgres
WAREHOUSE_URL=postgresql+psycopg2://etl:etl@localhost:5432/opendata

# Source Postgres connections (keyed by `conn` name in sources.yml)
ISOC_OPENDATA_URL=postgresql+psycopg2://reader:password@10.147.250.120:5432/isoc_opendata

# Optional Socrata app token (raises rate limits; not required)
SOCRATA_APP_TOKEN=

# Path to the registry
SOURCES_FILE=config/sources.yml
SOURCES_EXTRA_FILE=config/sources_extra.yml

# Google Sheet CSV export (used by scripts/sync_registry.py)
